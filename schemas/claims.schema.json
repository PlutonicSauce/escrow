    "id": { "type": "string", "minLength": 1 },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "positiveInteger": { "type": "integer", "minimum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "packageManager": { "type": "string", "enum": ["npm", "pnpm", "yarn"] }
